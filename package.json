{
  "name": "agent-worth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun turbo dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "test": "bun test",
    "build": "bun run --bun turbo build",
    "check:types": "bun run --bun turbo check:types",
    "check:codestyle": "bun run --bun biome check",
    "check:all": "bun check:types && bun check:codestyle",
    "check:commit-message": "bun run --bun commitlint",
    "fix:codestyle": "bun run --bun biome check --write",
    "typecheck": "bun check:types",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:check": "bun run --cwd packages/db db:check"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^6.0.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
