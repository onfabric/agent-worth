{
  "name": "agent-worth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "test": "bun test",
    "typecheck": "bun run typecheck:shared && bun run typecheck:db && bun run typecheck:api && bun run typecheck:daemon && bun run typecheck:web",
    "typecheck:shared": "bun run --cwd packages/shared typecheck",
    "typecheck:db": "bun run --cwd packages/db typecheck",
    "typecheck:api": "bun run --cwd apps/api typecheck",
    "typecheck:daemon": "bun run --cwd apps/daemon typecheck",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "build": "bun run build:shared && bun run build:db && bun run build:api && bun run build:daemon && bun run build:web",
    "build:shared": "bun run --cwd packages/shared build",
    "build:db": "bun run --cwd packages/db build",
    "build:api": "bun run --cwd apps/api build",
    "build:daemon": "bun run --cwd apps/daemon build",
    "build:web": "bun run --cwd apps/web build",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:check": "bun run --cwd packages/db db:check"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
