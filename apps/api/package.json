{
  "name": "@agent-worth/api",
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "check:types": "bun run --bun tsc -p tsconfig.json --noEmit",
    "typecheck": "bun run check:types"
  },
  "dependencies": {
    "@agent-worth/db": "workspace:*",
    "@agent-worth/shared": "workspace:*",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "elysia": "^1.4.28",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@agent-worth/typescript-config": "workspace:*",
    "typescript": "catalog:"
  }
}
